# Copy to .env.docker before running docker compose.

# PostgreSQL
POSTGRES_DB=truyenfullvn
POSTGRES_USER=truyenfullvn
POSTGRES_PASSWORD=change-this-long-random-password
DATABASE_URL=postgresql://truyenfullvn:change-this-long-random-password@postgres:5432/truyenfullvn

# FastAPI
SECRET_KEY=change-this-long-random-secret
ADMIN_TOKEN=change-this-admin-token
SITE_URL=https://truyenfullvn.org
LOG_LEVEL=INFO

# Redis/cache
CACHE_TRENDING_TTL=300
CACHE_RELATED_TTL=600
CACHE_SEARCH_TTL=300
CACHE_HOMEPAGE_TTL=300
CACHE_RECENT_TTL=300

# Rate limits
LOGIN_RATE_LIMIT=5/minute
REGISTER_RATE_LIMIT=3/minute
COMMENT_RATE_LIMIT=10/minute
BOOKMARK_RATE_LIMIT=20/minute
