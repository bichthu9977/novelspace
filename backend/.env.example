# Redis cache
CACHE_ENABLED=true
REDIS_URL=redis://localhost:6379/0
CACHE_KEY_PREFIX=truyenfullvn
CACHE_DEFAULT_TTL=300
CACHE_TRENDING_TTL=300
CACHE_RELATED_TTL=300
CACHE_SEARCH_TTL=120
CACHE_HOMEPAGE_TTL=300
CACHE_RECENT_TTL=300
LOG_LEVEL=INFO

# Rate limiting
RATE_LIMIT_STORAGE_URL=redis://localhost:6379/1
LOGIN_RATE_LIMIT=5/minute
REGISTER_RATE_LIMIT=3/minute
COMMENT_RATE_LIMIT=10/minute
BOOKMARK_RATE_LIMIT=20/minute
